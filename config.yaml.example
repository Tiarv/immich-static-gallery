albums:
  - id: "album-uuid-from-immich"
    # Use only letters, numbers, dots, underscores, and hyphens
    slug: "family-vacation"
    title: "Family Vacation"

scan:
  intervalMinutes: 60


gallery:
  engine: "thumbsup"
  flags:
    - "--theme"
    - "cards"
    - "--title"
    - "Gallery"
    - "--cleanup"
    - "true"
    - "--sort-media-direction"
    - "desc"

# Optional: Send a notification when the gallery is updated
notify:
  # URL to send a POST request to when changes are detected
  webhookUrl: ""
  # Set to true to fail the current sync when the webhook request fails.
  # In once mode this exits non-zero. In watch mode the failure is logged and
  # the next scheduled sync still runs.
  failOnError: false
